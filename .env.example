DB_PATH=./price-tracker.db
POLL_INTERVAL_HOURS=6

# Set to "false" to open a visible Chrome window (recommended for Total Wine).
BROWSER_HEADLESS=false

# Set to "system" to use your real Chrome profile (bypasses bot detection).
# Requires Chrome to be fully closed before running!
# If unset, uses a dedicated .chrome-profile/ in the project directory.
# CHROME_PROFILE=system

# Dashboard web UI port (default: 3000)
DASHBOARD_PORT=3000
